{
    "name": "n0mercy/training-package",
    "version": "1.0.0",
    "config": {
        "platform": {
            "php": "8.2"
        }
    },
    "autoload": {
        "psr-4": {
            "N0mercy\\TrainingPackage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "N0mercy\\TrainingPackage\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "l.veshkurcev",
            "email": "leonidveshkurcev@gmail.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "deptrac/deptrac": "^4.6",
        "phpstan/phpstan": "^2.1",
        "fakerphp/faker": "^1.24"
    },
    "scripts": {
        "tests": "vendor/bin/phpunit -c phpunit.xml.dist",
        "deptrac": "php vendor/bin/deptrac analyse --config-file=deptrac-layers.yaml",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "analyse": [
            "@deptrac",
            "@phpstan",
            "@tests"
        ]
    }
}
